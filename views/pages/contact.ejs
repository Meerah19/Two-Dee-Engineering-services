<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %> - Two Dee Engineering</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 50%, #f1f5f9 100%);
            color: #0f172a;
            min-height: 100vh;
        }
        
        /* Navigation Card */
        .nav-card {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-radius: 50px;
            border: 1px solid rgba(44, 94, 46, 0.15);
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
            z-index: 1000;
            padding: 8px 20px;
        }
        .nav-container {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: nowrap;
        }
        .nav-link {
            padding: 8px 18px;
            color: #334155;
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
            border-radius: 40px;
            white-space: nowrap;
            transition: all 0.3s;
        }
        .nav-link:hover { background: rgba(44, 94, 46, 0.1); color: #2C5E2E; }
        .admin-link {
            background: linear-gradient(135deg, #2C5E2E, #800020);
            color: white !important;
        }
        .admin-link:hover { background: linear-gradient(135deg, #3D7A3F, #A00028); transform: translateY(-1px); }
        
        @media (max-width: 768px) {
            .nav-card { width: 92%; padding: 6px 12px; overflow-x: auto; scrollbar-width: none; }
            .nav-card::-webkit-scrollbar { display: none; }
            .nav-container { display: inline-flex; gap: 4px; }
            .nav-link { padding: 6px 14px; font-size: 13px; }
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 140px 40px 80px;
        }
        
        .page-title {
            text-align: center;
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #0f172a, #2C5E2E);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .footer {
            background: #0f172a;
            color: white;
            padding: 60px 40px 30px;
            margin-top: 60px;
            text-align: center;
        }
        
        @media (max-width: 768px) {
            .container { padding: 120px 20px 60px; }
            .page-title { font-size: 32px; }
        }
    </style>
</head>
<body>
    <div class="nav-card">
        <div class="nav-container">
            <a href="/" class="nav-link">Home</a>
            <a href="/services" class="nav-link">Services</a>
            <a href="/projects" class="nav-link">Projects</a>
            <a href="/about" class="nav-link">About</a>
            <a href="/contact" class="nav-link">Contact</a>
            <a href="/admin/login" class="nav-link admin-link">🔐 Admin</a>
        </div>
    </div>
    
    <div class="container">
        <h1 class="page-title"><%= pageTitle %></h1>
        <div style="background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border-radius: 24px; padding: 40px; border: 1px solid rgba(44,94,46,0.1);">
            <%= content %>
        </div>
    </div>
    
    <footer class="footer">
        <p>&copy; 2024 Two Dee Engineering Services. All rights reserved.</p>
        <p style="margin-top: 10px; font-size: 12px;">Licensed PE: TX-123456 | CA-789101</p>
    </footer>
</body>
</html>
