<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Two Dee Engineering - Precision Engineering</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 50%, #f1f5f9 100%);
            color: #0f172a;
            overflow-x: hidden;
        }

        /* Animated Tech Background */
        .tech-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
        }

        .tech-bg::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background-image: 
                linear-gradient(rgba(44, 94, 46, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(44, 94, 46, 0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            animation: gridMove 20s linear infinite;
        }

        @keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(40px, 40px); }
        }

        .tech-circles {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 50%, rgba(44, 94, 46, 0.02) 0%, transparent 50%);
            animation: rotate 30s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Navigation - Fixed Card Style */
        .nav-card {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-radius: 50px;
            border: 1px solid rgba(44, 94, 46, 0.15);
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
            z-index: 1000;
            padding: 8px 20px;
        }

        .nav-container {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: nowrap;
        }

        .nav-link {
            padding: 8px 18px;
            color: #334155;
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
            transition: all 0.3s ease;
            border-radius: 40px;
            white-space: nowrap;
        }

        .nav-link:hover {
            background: rgba(44, 94, 46, 0.1);
            color: #2C5E2E;
        }

        /* Admin Button */
        .admin-link {
            background: linear-gradient(135deg, #2C5E2E, #800020);
            color: white !important;
        }

        .admin-link:hover {
            background: linear-gradient(135deg, #3D7A3F, #A00028);
            transform: translateY(-1px);
        }

        /* Mobile Navigation - Horizontal Scroll with Fixed Card */
        @media (max-width: 768px) {
            .nav-card {
                top: 15px;
                width: 92%;
                padding: 6px 12px;
                border-radius: 50px;
                overflow-x: auto;
                overflow-y: hidden;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
            }
            
            .nav-card::-webkit-scrollbar {
                display: none;
            }
            
            .nav-container {
                display: inline-flex;
                gap: 4px;
            }
            
            .nav-link {
                padding: 6px 14px;
                font-size: 13px;
            }
        }

        /* Tablet */
        @media (min-width: 769px) and (max-width: 1024px) {
            .nav-card {
                width: auto;
                max-width: 90%;
            }
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 140px 40px 80px;
            position: relative;
            z-index: 1;
        }

        /* Hero Section */
        .hero {
            text-align: center;
            padding: 60px 0 40px;
        }

        .hero-badge {
            display: inline-block;
            padding: 8px 20px;
            background: linear-gradient(135deg, rgba(44, 94, 46, 0.1), rgba(128, 0, 32, 0.1));
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            color: #2C5E2E;
            margin-bottom: 30px;
        }

        .hero h1 {
            font-size: 56px;
            font-weight: 800;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #0f172a 0%, #2C5E2E 40%, #800020 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1.2;
        }

        .hero-subtitle {
            font-size: 20px;
            color: #475569;
            margin-bottom: 40px;
            font-weight: 500;
        }

        .hero p {
            font-size: 18px;
            color: #64748b;
            margin-bottom: 40px;
            line-height: 1.6;
        }

        /* Buttons */
        .btn-primary {
            display: inline-block;
            padding: 14px 35px;
            background: linear-gradient(135deg, #2C5E2E 0%, #800020 100%);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            margin: 0 10px;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(44, 94, 46, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(44, 94, 46, 0.3);
        }

        .btn-outline {
            display: inline-block;
            padding: 14px 35px;
            background: transparent;
            border: 2px solid #2C5E2E;
            color: #2C5E2E;
            text-decoration: none;
            border-radius: 50px;
            margin: 0 10px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-outline:hover {
            background: #2C5E2E;
            color: white;
            transform: translateY(-2px);
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin: 80px 0;
        }

        .stat-card {
            text-align: center;
            padding: 35px 25px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            transition: all 0.3s;
            border: 1px solid rgba(44, 94, 46, 0.1);
        }

        .stat-card:hover {
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.95);
            border-color: rgba(44, 94, 46, 0.2);
        }

        .stat-number {
            font-size: 48px;
            font-weight: 800;
            background: linear-gradient(135deg, #2C5E2E, #800020);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-label {
            color: #64748b;
            font-weight: 500;
            margin-top: 10px;
        }

        /* Section Title */
        .section-title {
            text-align: center;
            font-size: 38px;
            font-weight: 700;
            margin: 60px 0 20px;
        }

        .section-title span {
            background: linear-gradient(135deg, #2C5E2E, #800020);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .section-subtitle {
            text-align: center;
            color: #64748b;
            margin-bottom: 50px;
            font-size: 18px;
        }

        /* Service Cards */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin-top: 30px;
        }

        .service-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            padding: 35px 25px;
            border-radius: 24px;
            transition: all 0.3s;
            border: 1px solid rgba(44, 94, 46, 0.1);
            text-align: center;
        }

        .service-card:hover {
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.95);
            border-color: rgba(44, 94, 46, 0.2);
        }

        .service-icon {
            font-size: 52px;
            margin-bottom: 20px;
            display: inline-block;
        }

        .service-card h3 {
            font-size: 20px;
            margin-bottom: 15px;
            color: #0f172a;
        }

        .service-card p {
            color: #64748b;
            line-height: 1.5;
            font-size: 14px;
        }

        /* CTA Section */
        .cta-section {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border-radius: 40px;
            padding: 60px;
            text-align: center;
            margin: 60px 0;
            border: 1px solid rgba(44, 94, 46, 0.1);
        }

        .cta-section h2 {
            font-size: 32px;
            margin-bottom: 15px;
        }

        /* Footer */
        .footer {
            background: #0f172a;
            color: white;
            padding: 60px 40px 30px;
            margin-top: 60px;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 40px;
        }

        .footer h4 {
            margin-bottom: 20px;
            color: #2C5E2E;
        }

        .footer a {
            color: #94a3b8;
            text-decoration: none;
            display: block;
            margin-bottom: 10px;
        }

        .footer a:hover {
            color: #2C5E2E;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 40px;
            margin-top: 40px;
            border-top: 1px solid rgba(255,255,255,0.1);
            color: #94a3b8;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .stats-grid, .services-grid, .footer-content {
                grid-template-columns: 1fr;
            }
            .hero h1 {
                font-size: 32px;
            }
            .hero-subtitle {
                font-size: 16px;
            }
            .hero p {
                font-size: 14px;
            }
            .container {
                padding: 120px 20px 60px;
            }
            .section-title {
                font-size: 28px;
            }
            .btn-primary, .btn-outline {
                padding: 10px 20px;
                font-size: 14px;
                margin: 5px;
            }
            .cta-section {
                padding: 30px 20px;
            }
            .cta-section h2 {
                font-size: 24px;
            }
        }

        @media (min-width: 769px) and (max-width: 1024px) {
            .stats-grid, .services-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .hero h1 {
                font-size: 44px;
            }
        }

        @media (max-width: 480px) {
            .hero h1 {
                font-size: 26px;
            }
        }
    </style>
</head>
